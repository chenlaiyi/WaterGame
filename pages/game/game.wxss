/* pages/game/game.wxss */

.game-page {
  padding: 20rpx;
  background: linear-gradient(135deg, #e3f2fd 0%, #f3e5f5 100%);
  min-height: 100vh;
}

/* 游戏状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx var(--shadow);
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.status-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.status-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.status-value.score {
  color: var(--success-color);
}

.status-value.time {
  color: var(--warning-color);
}

.status-value.time.urgent {
  color: var(--error-color);
  animation: pulse 1s infinite;
}

/* 连击显示 */
.combo-display {
  text-align: center;
  margin-bottom: 20rpx;
}

.combo-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
  animation: bounce 0.5s ease;
}

/* 游戏区域 */
.game-area {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 40rpx var(--shadow);
}

.game-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  grid-gap: 4rpx;
  background: var(--border-color);
  border-radius: 10rpx;
  padding: 10rpx;
}

.game-block {
  aspect-ratio: 1;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  cursor: pointer;
  /* 优化：使用transform3d启用硬件加速 */
  transform: translate3d(0, 0, 0);
  will-change: transform;
  overflow: hidden;
}

.game-block:active {
  transform: scale(0.95) translate3d(0, 0, 0);
}

/* 污染物方块样式 */
.block-particle {
  background: linear-gradient(135deg, var(--particle-color) 0%, #a0522d 100%);
  color: white;
}

.block-microbe {
  background: linear-gradient(135deg, var(--microbe-color) 0%, #32cd32 100%);
  color: white;
}

.block-chemical {
  background: linear-gradient(135deg, var(--chemical-color) 0%, #9370db 100%);
  color: white;
}

.block-selected {
  border: 4rpx solid #ffd700;
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.6);
  transform: scale(1.1) translate3d(0, 0, 0);
}

.block-eliminating {
  animation: eliminate 0.5s ease-out forwards;
}

/* 消除动画 */
@keyframes eliminate {
  0% {
    transform: scale(1) translate3d(0, 0, 0);
    opacity: 1;
  }
  50% {
    transform: scale(1.2) translate3d(0, 0, 0);
    opacity: 0.7;
  }
  100% {
    transform: scale(0) translate3d(0, 0, 0);
    opacity: 0;
  }
}

/* 道具栏 */
.powerup-bar {
  display: flex;
  justify-content: space-between;
  margin: 30rpx 0;
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.1);
}

.powerup-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  cursor: pointer;
}

.powerup-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
  background: var(--bg-light);
}

.powerup-count {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.powerup-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 功能按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-buttons .btn {
  flex: 1;
  padding: 20rpx;
  font-size: 28rpx;
}

/* 暂停/游戏结束弹窗 */
.pause-modal, .gameover-modal {
  max-width: 500rpx;
}

.gameover-content {
  text-align: center;
  margin: 30rpx 0;
}

.final-score {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 20rpx;
}

.level-completed {
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 响应式适配 */
@media (max-width: 400px) {
  .status-bar {
    padding: 15rpx 20rpx;
  }
  
  .status-value {
    font-size: 28rpx;
  }
  
  .powerup-bar {
    padding: 15rpx;
  }
  
  .powerup-icon {
    width: 60rpx;
    height: 60rpx;
    font-size: 30rpx;
  }
  
  .action-buttons {
    gap: 10rpx;
  }
  
  .action-buttons .btn {
    padding: 15rpx;
    font-size: 24rpx;
  }
}