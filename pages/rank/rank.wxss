/* pages/rank/rank.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
  text-align: left;
}

.nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.user-rank {
  display: flex;
  justify-content: space-between;
}

.user-rank text {
  font-size: 24rpx;
  color: #666;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-right: 1rpx solid #eee;
}

.tab:last-child {
  border-right: none;
}

.tab.active {
  color: #1296db;
  font-weight: bold;
  border-bottom: 4rpx solid #1296db;
}

.rank-content {
  height: calc(100vh - 350rpx);
}

.rank-list {
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  margin-bottom: 30rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-item.top-three {
  background: linear-gradient(to right, #fff9c4, #fff);
}

.rank-number {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #999;
}

.rank-number.top-rank {
  font-size: 24rpx;
}

.medal {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  border-radius: 50%;
  color: #fff;
  font-weight: bold;
}

.medal-1 {
  background-color: #ff9800;
}

.medal-2 {
  background-color: #9e9e9e;
}

.medal-3 {
  background-color: #795548;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 0 20rpx;
}

.user-info {
  flex: 1;
}

.user-nickname {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.user-score, .user-level, .user-coins {
  font-size: 24rpx;
  color: #666;
}

.actions {
  display: flex;
  justify-content: space-between;
}

.action-btn {
  flex: 1;
  background-color: #1296db;
  color: #fff;
  border: none;
  padding: 20rpx;
  margin: 0 10rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}