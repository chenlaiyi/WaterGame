/* pages/shop/shop.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.nickname {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.coins {
  font-size: 24rpx;
  color: #ff9800;
  background-color: #fffde7;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-right: 1rpx solid #eee;
}

.tab:last-child {
  border-right: none;
}

.tab.active {
  color: #1296db;
  font-weight: bold;
  border-bottom: 4rpx solid #1296db;
}

.content {
  height: calc(100vh - 200rpx);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 8rpx solid #1296db;
}

/* 产品列表样式 */
.product-list {
  margin-bottom: 30rpx;
}

.product-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  position: relative;
}

.product-image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.product-info {
  margin-bottom: 20rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.product-tags {
  margin-bottom: 10rpx;
}

.tag {
  font-size: 20rpx;
  color: #1296db;
  background-color: #e3f2fd;
  padding: 5rpx 10rpx;
  border-radius: 5rpx;
  margin-right: 10rpx;
}

.product-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 10rpx;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #f44336;
  margin-right: 10rpx;
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.product-sales {
  font-size: 24rpx;
  color: #999;
}

.share-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background-color: #1296db;
  color: #fff;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

/* 品牌信息样式 */
.brand-section {
  margin-top: 30rpx;
}

.brand-info {
  display: flex;
  justify-content: space-between;
}

.info-btn {
  flex: 1;
  background-color: #1296db;
  color: #fff;
  border: none;
  padding: 20rpx;
  margin: 0 10rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
}

/* 优惠券列表样式 */
.coupon-list {
  margin-bottom: 30rpx;
}

.coupon-item {
  background: linear-gradient(to right, #ff9800, #ff5722);
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  position: relative;
}

.coupon-left {
  width: 30%;
  text-align: center;
  color: #fff;
  border-right: 2rpx dashed #fff;
  padding-right: 20rpx;
}

.coupon-amount {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.coupon-condition {
  font-size: 24rpx;
}

.coupon-right {
  width: 70%;
  padding-left: 20rpx;
  color: #fff;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.coupon-validity {
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.coupon-type {
  font-size: 20rpx;
  background-color: rgba(255, 255, 255, 0.3);
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
  display: inline-block;
}

.claim-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background-color: #fff;
  color: #ff5722;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

/* 知识列表样式 */
.knowledge-list {
  margin-bottom: 30rpx;
}

.knowledge-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.knowledge-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.knowledge-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 底部样式 */
.footer {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
}

.support-btn {
  width: 100%;
  background-color: #4caf50;
  color: #fff;
  border: none;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}