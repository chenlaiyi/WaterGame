/**app.wxss**/
/* 点点够净水器小游戏 - 全局样式 */

/* =============  全局样式重置  ============= */
page {
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #333;
  font-size: 32rpx;
  line-height: 1.4;
}

* {
  box-sizing: border-box;
}

/* =============  品牌色彩主题  ============= */
:root {
  /* 点点够品牌主色 */
  --primary-color: #1296db;
  --primary-light: #42a5f5; 
  --primary-dark: #0d47a1;
  
  /* 净水主题色 */
  --water-blue: #e3f2fd;
  --water-light: #f3e5f5;
  --clean-white: #ffffff;
  
  /* 污染物颜色 */
  --particle-color: #8b4513;
  --microbe-color: #228b22;
  --chemical-color: #8a2be2;
  
  /* 功能色彩 */
  --success-color: #4caf50;
  --warning-color: #ff9800;
  --error-color: #f44336;
  --info-color: #2196f3;
  
  /* 中性色 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-disabled: #999999;
  --border-color: #e0e0e0;
  --bg-light: #f5f5f5;
  --shadow: rgba(0, 0, 0, 0.1);
}

/* =============  通用布局类  ============= */
.container {
  width: 100%;
  min-height: 100vh;
  padding: 20rpx;
  background: linear-gradient(135deg, var(--water-blue) 0%, var(--water-light) 100%);
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
}

/* =============  按钮组件  ============= */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s;
}

.btn:hover::before {
  left: 100%;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(18, 150, 219, 0.3);
}

.btn-success {
  background: linear-gradient(135deg, var(--success-color) 0%, #66bb6a 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
}

.btn-warning {
  background: linear-gradient(135deg, var(--warning-color) 0%, #ffb74d 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(255, 152, 0, 0.3);
}

.btn-danger {
  background: linear-gradient(135deg, var(--error-color) 0%, #e57373 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(244, 67, 54, 0.3);
}

.btn-outline {
  background: transparent;
  border: 3rpx solid var(--primary-color);
  color: var(--primary-color);
}

.btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 10rpx var(--shadow);
}

.btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none !important;
}

/* =============  卡片组件  ============= */
.card {
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx var(--shadow);
  padding: 30rpx;
  margin: 20rpx 0;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.card-content {
  color: var(--text-secondary);
  line-height: 1.6;
}

/* =============  游戏区域样式  ============= */
.game-area {
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 40rpx var(--shadow);
}

.game-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  grid-gap: 4rpx;
  background: var(--border-color);
  border-radius: 10rpx;
  padding: 10rpx;
}

.game-cell {
  aspect-ratio: 1;
  background: white;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.game-cell:hover {
  transform: scale(1.05);
  box-shadow: 0 4rpx 15rpx var(--shadow);
}

.game-cell.selected {
  border: 4rpx solid var(--primary-color);
  transform: scale(1.1);
}

.game-cell.matched {
  animation: matchPop 0.3s ease;
}

@keyframes matchPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(0); }
}

/* =============  污染物样式  ============= */
.pollutant {
  width: 80%;
  height: 80%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-weight: bold;
  font-size: 24rpx;
}

.pollutant.particle {
  background: linear-gradient(135deg, var(--particle-color) 0%, #cd853f 100%);
}

.pollutant.microbe {
  background: linear-gradient(135deg, var(--microbe-color) 0%, #32cd32 100%);
}

.pollutant.chemical {
  background: linear-gradient(135deg, var(--chemical-color) 0%, #9370db 100%);
}

/* =============  得分和状态栏  ============= */
.score-bar {
  background: white;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 15rpx var(--shadow);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-item {
  text-align: center;
  flex: 1;
}

.score-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-color);
}

/* =============  进度条  ============= */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background: var(--border-color);
  border-radius: 6rpx;
  overflow: hidden;
  position: relative;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 6rpx;
  transition: width 0.3s ease;
  position: relative;
}

.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: progressShine 2s infinite;
}

@keyframes progressShine {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* =============  模态框和弹窗  ============= */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 40rpx;
  max-width: 600rpx;
  animation: slideUp 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(100rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* =============  品牌展示区域  ============= */
.brand-showcase {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  text-align: center;
}

.brand-logo {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.brand-slogan {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.brand-features {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.brand-feature {
  text-align: center;
}

.brand-feature-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.brand-feature-text {
  font-size: 24rpx;
  opacity: 0.8;
}

/* =============  列表和表格  ============= */
.list-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 12rpx 0;
  box-shadow: 0 4rpx 12rpx var(--shadow);
  transition: all 0.2s ease;
}

.list-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx var(--shadow);
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.list-subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.list-badge {
  background: var(--primary-color);
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* =============  输入框组件  ============= */
.input-group {
  margin: 20rpx 0;
}

.input-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.input-field {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 32rpx;
  transition: all 0.2s ease;
}

.input-field:focus {
  border-color: var(--primary-color);
  outline: none;
  box-shadow: 0 0 0 6rpx rgba(18, 150, 219, 0.1);
}

/* =============  徽章和标签  ============= */
.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.badge-primary {
  background: var(--primary-color);
  color: white;
}

.badge-success {
  background: var(--success-color);
  color: white;
}

.badge-warning {
  background: var(--warning-color);
  color: white;
}

.badge-danger {
  background: var(--error-color);
  color: white;
}

/* =============  响应式设计  ============= */
@media screen and (max-width: 768rpx) {
  .game-grid {
    grid-gap: 3rpx;
    padding: 8rpx;
  }
  
  .btn {
    padding: 20rpx 40rpx;
    font-size: 28rpx;
  }
  
  .card {
    padding: 24rpx;
    margin: 16rpx 0;
  }
}

/* =============  动画效果  ============= */
.bounce {
  animation: bounce 0.6s ease;
}

@keyframes bounce {
  0%, 20%, 60%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-20rpx);
  }
  80% {
    transform: translateY(-10rpx);
  }
}

.shake {
  animation: shake 0.5s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10rpx); }
  20%, 40%, 60%, 80% { transform: translateX(10rpx); }
}

.pulse {
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.05);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

/* =============  辅助工具类  ============= */
.hidden {
  display: none !important;
}

.invisible {
  visibility: hidden;
}

.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.font-bold {
  font-weight: bold;
}

.font-normal {
  font-weight: normal;
}

.mb-0 { margin-bottom: 0; }
.mb-1 { margin-bottom: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }

.mt-0 { margin-top: 0; }
.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }

.p-0 { padding: 0; }
.p-1 { padding: 8rpx; }
.p-2 { padding: 16rpx; }
.p-3 { padding: 24rpx; }
.p-4 { padding: 32rpx; }

/* =============  主题色变量补充  ============= */
.bg-primary { background-color: var(--primary-color); }
.bg-success { background-color: var(--success-color); }
.bg-warning { background-color: var(--warning-color); }
.bg-danger { background-color: var(--error-color); }
.bg-light { background-color: var(--bg-light); }

.text-primary { color: var(--primary-color); }
.text-success { color: var(--success-color); }
.text-warning { color: var(--warning-color); }
.text-danger { color: var(--error-color); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-disabled); }