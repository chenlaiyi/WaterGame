# 点点够净水消消乐环境配置示例文件
# 复制此文件为 .env 并填写实际值

# 微信云开发配置
CLOUD_ENV_ID=your-cloud-environment-id
CLOUD_REGION=ap-shanghai

# 数据库配置
DB_NAME=water_game_db
DB_HOST=localhost
DB_PORT=27017
DB_USER=water_game_user
DB_PASSWORD=your_database_password

# 微信API配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 广告配置
AD_UNIT_ID_REWARDED=your-rewarded-ad-unit-id
AD_UNIT_ID_INTERSTITIAL=your-interstitial-ad-unit-id

# 支付配置
MCH_ID=your-merchant-id
MCH_KEY=your-merchant-key

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/water-game.log

# 性能配置
GAME_FPS=60
MAX_CONCURRENT_USERS=1000